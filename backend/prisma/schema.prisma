generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  FREELANCER
}

enum ContractStatus {
  DRAFT
  ACTIVE
  IN_PROGRESS
  COMPLETED
  DISPUTED
  CANCELLED
}

enum MilestoneStatus {
  PENDING
  SUBMITTED
  APPROVED
  REJECTED
  DISPUTED
}

enum TransactionType {
  ESCROW_FUNDED
  MILESTONE_RELEASED
  REFUNDED
  DISPUTED_HOLD
}

enum VerdictResult {
  APPROVE
  REQUEST_CHANGES
  ESCALATE
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_CLIENT
  RESOLVED_FREELANCER
}

enum DisputeReason {
  WORK_INCOMPLETE
  WORK_NOT_AS_DESCRIBED
  PAYMENT_DELAYED
  GHOST_DETECTED
  OTHER
}

enum GhostEventType {
  CLIENT_SILENT
  FREELANCER_ABANDONED
}

enum GhostAction {
  AUTO_RELEASED
  PAYMENT_LOCKED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contractsAsClient     Contract[] @relation("ClientContracts")
  contractsAsFreelancer Contract[] @relation("FreelancerContracts")
}

model Contract {
  id           String         @id @default(uuid())
  title        String
  description  String
  totalAmount  Decimal        @db.Decimal(10, 2)
  status       ContractStatus @default(DRAFT)
  clientId     String
  freelancerId String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  client       User          @relation("ClientContracts", fields: [clientId], references: [id])
  freelancer   User          @relation("FreelancerContracts", fields: [freelancerId], references: [id])
  milestones   Milestone[]
  transactions Transaction[]
  disputes     Dispute[]
  ghostEvents  GhostEvent[]
  aiVerdicts   AIVerdict[]
}

model Milestone {
  title             String
  id                String          @id @default(uuid())
  description       String
  amount            Decimal         @db.Decimal(10, 2)
  status            MilestoneStatus @default(PENDING)
  dueDate           DateTime
  contractId        String
  submissionNotes   String?
  submissionUrl     String?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  contract   Contract    @relation(fields: [contractId], references: [id])
  aiVerdicts AIVerdict[]
  disputes   Dispute[]
}

model Transaction {
  id             String          @id @default(uuid())
  type           TransactionType
  amount         Decimal         @db.Decimal(10, 2)
  contractId     String
  milestoneId    String?
  idempotencyKey String          @unique
  meta           Json?
  createdAt      DateTime        @default(now())

  contract Contract @relation(fields: [contractId], references: [id])
}

model AIVerdict {
  id          String        @id @default(uuid())
  verdict     VerdictResult
  confidence  Float
  reasoning   String
  contractId  String
  milestoneId String
  createdAt   DateTime      @default(now())

  contract  Contract  @relation(fields: [contractId], references: [id])
  milestone Milestone @relation(fields: [milestoneId], references: [id])
}

model Dispute {
  id          String        @id @default(uuid())
  status      DisputeStatus @default(OPEN)
  reason      DisputeReason
  description String
  contractId  String
  milestoneId String?
  raisedById  String
  resolvedAt  DateTime?
  resolution  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  contract  Contract   @relation(fields: [contractId], references: [id])
  milestone Milestone? @relation(fields: [milestoneId], references: [id])
}

model GhostEvent {
  id          String         @id @default(uuid())
  type        GhostEventType
  action      GhostAction
  contractId  String
  triggeredAt DateTime       @default(now())
  processed   Boolean        @default(false)

  contract Contract @relation(fields: [contractId], references: [id])
}